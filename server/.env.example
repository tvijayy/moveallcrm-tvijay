# Server
PORT=5000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/moveall_crm

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_EXPIRES_IN=24h

# n8n Webhook Integration
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/moveall-crm
N8N_WEBHOOK_TIMEOUT=10000

# CORS
CORS_ORIGIN=http://localhost:3000
